# ============================================================
# Atomic Swarm Gods Elite v1.7.0 - pnpm/npm Configuration
# ============================================================

strict-peer-dependencies=false
auto-install-peers=true
legacy-peer-deps=true

registry=https://registry.npmjs.org/
@atomic-gods:registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

audit-level=high
fund=false

fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Removed invalid lockfile-version=6.0
frozen-lockfile=true

access=public
provenance=true

workspaces-update=false
engine-strict=false
save-exact=true
save-prefix=''
resolution-mode=highest
cache=~/.pnpm-store
loglevel=notice
progress=false
git-tag-version=false