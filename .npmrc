# ============================================================
# Atomic Swarm Gods Elite v1.7.0 - pnpm Configuration
# Enterprise-grade settings for reproducibility & security
# ============================================================

# ----------------------------
# Package Manager Behaviour
# ----------------------------
# Prevent peer dependency warnings from breaking CI
strict-peer-dependencies=false
auto-install-peers=true

# Use legacy peer deps as fallback (safer for large workspaces)
legacy-peer-deps=true

# ----------------------------
# Registry & Authentication
# ----------------------------
registry=https://registry.npmjs.org/
@atomic-gods:registry=https://registry.npmjs.org/

# Never hardcode tokens – use NPM_TOKEN environment variable
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# ----------------------------
# Security & Audit
# ----------------------------
audit-level=high
fund=false

# ----------------------------
# Performance & Retries
# ----------------------------
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# ----------------------------
# Lockfile – Always keep lockfile for reproducible builds
# ----------------------------
# pnpm uses pnpm-lock.yaml – do not disable
# The following are pnpm‑specific
lockfile-version=6.0          # Use latest lockfile format
frozen-lockfile=true          # Fail if lockfile is out of sync (for CI)

# ----------------------------
# Publishing
# ----------------------------
access=public
provenance=true               # Enable npm provenance for supply chain security

# ----------------------------
# Workspaces (monorepo support)
# ----------------------------
workspaces-update=false

# ----------------------------
# Version Strictness
# ----------------------------
engine-strict=false

# ----------------------------
# Save exact versions (no ^ or ~)
# ----------------------------
save-exact=true
save-prefix=''                # Remove semver prefix

# ----------------------------
# Dependency resolution
# ----------------------------
resolution-mode=highest        # pnpm-specific – picks highest compatible version

# ----------------------------
# Cache & Logging
# ----------------------------
cache=~/.pnpm-store
loglevel=notice
progress=false

# ----------------------------
# Git integration
# ----------------------------
git-tag-version=false

# ----------------------------
# Elite Enterprise Features
# ----------------------------
# Blockchain audit for published packages (requires npm provenance)