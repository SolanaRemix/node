# ============================================================
# Atomic Swarm Gods Elite v1.7.0 - pnpm/npm Configuration
# Enterprise-grade settings for reproducibility & security
# ============================================================

# ----------------------------
# Package Manager Behaviour
# ----------------------------
# Prevent peer dependency warnings from breaking CI
strict-peer-dependencies=false
auto-install-peers=true

# Use legacy peer deps as fallback (safer for large workspaces)
legacy-peer-deps=true

# ----------------------------
# Registry & Authentication
# ----------------------------
registry=https://registry.npmjs.org/
@atomic-gods:registry=https://registry.npmjs.org/

# Never hardcode tokens – use NPM_TOKEN environment variable
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# ----------------------------
# Security & Audit
# ----------------------------
audit-level=high
fund=false

# ----------------------------
# Performance & Retries
# ----------------------------
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# ----------------------------
# Lockfile – No global lockfile-version (pnpm uses its own lockfile version)
# ------------------------------------------
# Note: npm does not accept lockfile-version >3, so we omit it.
# pnpm will use the version from pnpm-lock.yaml (currently 6.0).
# ------------------------------------------
frozen-lockfile=true          # Fail if lockfile is out of sync (CI only – set to false locally)

# ----------------------------
# Publishing
# ----------------------------
access=public
provenance=true               # Enable npm provenance for supply chain security

# ----------------------------
# Workspaces (monorepo support)
# ----------------------------
workspaces-update=false

# ----------------------------
# Version Strictness
# ----------------------------
engine-strict=false

# ----------------------------
# Save exact versions (no ^ or ~)
# ----------------------------
save-exact=true
save-prefix=''                # Remove semver prefix

# ----------------------------
# Dependency resolution
# ----------------------------
resolution-mode=highest        # pnpm-specific – picks highest compatible version

# ----------------------------
# Cache & Logging
# ----------------------------
cache=~/.pnpm-store
loglevel=notice
progress=false

# ----------------------------
# Git integration
# ----------------------------
git-tag-version=false

# ----------------------------
# Elite Enterprise Features
# ----------------------------
# Blockchain audit for published packages (requires npm provenance)