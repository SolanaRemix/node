# ============================================================
# Atomic Swarm Gods Elite v1.7.0 - pnpm Configuration
# Enterprise-grade settings for reproducibility & security
# ============================================================

# ----------------------------
# Package Manager Behaviour
# ----------------------------
strict-peer-dependencies=false
auto-install-peers=true
legacy-peer-deps=true

# ----------------------------
# Registry & Authentication
# ----------------------------
registry=https://registry.npmjs.org/
@atomic-gods:registry=https://registry.npmjs.org/

# Never hardcode tokens – use NPM_TOKEN environment variable
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# ----------------------------
# Security & Audit
# ----------------------------
audit-level=high
fund=false

# ----------------------------
# Performance & Retries
# ----------------------------
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# ----------------------------
# Lockfile – Removed invalid lockfile-version=6.0 (npm only accepts 1-3)
# pnpm will use its own pnpm-lock.yaml version.
# ----------------------------
frozen-lockfile=true          # Fail if lockfile is out of sync (for CI)

# ----------------------------
# Publishing
# ----------------------------
access=public
provenance=true

# ----------------------------
# Workspaces (monorepo support)
# ----------------------------
workspaces-update=false

# ----------------------------
# Version Strictness
# ----------------------------
engine-strict=false

# ----------------------------
# Save exact versions (no ^ or ~)
# ----------------------------
save-exact=true
save-prefix=''

# ----------------------------
# Dependency resolution
# ----------------------------
resolution-mode=highest

# ----------------------------
# Cache & Logging
# ----------------------------
cache=~/.pnpm-store
loglevel=notice
progress=false

# ----------------------------
# Git integration
# ----------------------------
git-tag-version=false

# ----------------------------
# Elite Enterprise Features
# ----------------------------
# Blockchain audit for published packages (requires npm provenance)