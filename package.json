{
    "name":  "@castquest/atomic-node",
    "version":  "1.3.0",
    "type":  "module",
    "scripts":  {
                    "build":  "tsc",
                    "start":  "node dist/index.js",
                    "test":  "node --test dist/*.test.js",
                    "typecheck":  "tsc --noEmit --strict",
                    "clean":  "node -e \"require(\u0027fs\u0027).rmSync(\u0027node_modules\u0027,{recursive:true,force:true}); require(\u0027fs\u0027).rmSync(\u0027pnpm-lock.yaml\u0027,{force:true}); require(\u0027fs\u0027).rmSync(\u0027package-lock.json\u0027,{force:true}); require(\u0027fs\u0027).rmSync(\u0027dist\u0027,{recursive:true,force:true})\"",
                    "repair":  "npm run clean \u0026\u0026 npm install \u0026\u0026 npm run build \u0026\u0026 npm run typecheck"
                },
    "devDependencies":  {
                            "@types/node":  "^20.11.0",
                            "typescript":  "^5.8.3"
                        }
}
